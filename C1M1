-style: normal;\n  font-weight: 800;\n  font-display: swap;\n  src: url(\"9f5629b3-e59f-47e1-bb01-09de2d9437d2\") format(\"truetype\");\n}\n\n/* Curio Group — Color tokens\n   Sampled from the official brand video backgrounds & logo.\n   Palette: deep petrol blue, forest green, sage, mustard, tomato,\n   cream paper, soft grey, charcoal ink. */\n\n:root {\n  /* ---- Base palette ---- */\n  --curio-petrol:        #004860; /* deep teal-blue — primary brand colour */\n  --curio-petrol-700:    #00374a;\n  --curio-petrol-300:    #4d7d90;\n\n  --curio-forest:        #00543c; /* forest green — primary brand colour */\n  --curio-forest-700:    #003e2c;\n  --curio-forest-300:    #4d8771;\n\n  --curio-sage:          #6c8460; /* muted olive/sage — secondary */\n  --curio-sage-300:      #9aab90;\n  --curio-sage-100:      #d3dccd;\n\n  --curio-mustard:       #f6c453; /* warm gold — energetic accent */\n  --curio-mustard-700:   #e0a92f;\n\n  --curio-tomato:        #ef4e26; /* tomato/coral — punchy accent */\n  --curio-tomato-700:    #cf3d18;\n\n  --curio-cream:         #f6f1e4; /* warm paper — primary light surface */\n  --curio-cream-deep:    #ece5d2;\n\n  --curio-grey:          #dde0dd; /* cool light grey */\n  --curio-grey-300:      #b7bdb8;\n  --curio-grey-500:      #8a918b;\n\n  --curio-ink:           #353a38; /* near-black charcoal — body text */\n  --curio-ink-soft:      #5c635f;\n  --curio-white:         #ffffff;\n\n  /* ---- Semantic surfaces ---- */\n  --surface-page:        var(--curio-cream);\n  --surface-card:        var(--curio-white);\n  --surface-inverse:     var(--curio-petrol);\n  --surface-inverse-alt: var(--curio-forest);\n  --surface-muted:       var(--curio-cream-deep);\n\n  /* ---- Semantic text ---- */\n  --text-strong:         var(--curio-ink);\n  --text-body:           var(--curio-ink-soft);\n  --text-on-dark:        var(--curio-cream);\n  --text-on-dark-muted:  rgba(246, 241, 228, 0.72);\n  --text-link:           var(--curio-petrol);\n\n  /* ---- Semantic accents ---- */\n  --accent-primary:      var(--curio-petrol);\n  --accent-secondary:    var(--curio-forest);\n  --accent-warm:         var(--curio-mustard);\n  --accent-hot:          var(--curio-tomato);\n\n  /* ---- Borders & lines ---- */\n  --border-subtle:       rgba(53, 58, 56, 0.12);\n  --border-strong:       rgba(53, 58, 56, 0.24);\n  --border-on-dark:      rgba(246, 241, 228, 0.24);\n\n  /* ---- Status ---- */\n  --status-success:      #2f7d54;\n  --status-warning:      var(--curio-mustard-700);\n  --status-error:        var(--curio-tomato-700);\n  --status-info:         var(--curio-petrol-300);\n}\n\n/* Curio Group — Typography tokens\n   Single typeface: Manrope. Display uses tight tracking + weight 800;\n   the wordmark style is ALL-CAPS with wide tracking. */\n\n:root {\n  --font-sans: \"Manrope\", \"Helvetica Neue\", Arial, sans-serif;\n  --font-display: \"Manrope\", \"Helvetica Neue\", Arial, sans-serif;\n\n  /* Weights */\n  --fw-light: 300; /* @kind font */\n  --fw-regular: 400; /* @kind font */\n  --fw-medium: 500; /* @kind font */\n  --fw-semibold: 600; /* @kind font */\n  --fw-bold: 700; /* @kind font */\n  --fw-extrabold: 800; /* @kind font */\n\n  /* Type scale (rem, 16px base) — major-third-ish, tuned for marketing */\n  --fs-display-xl: 4.5rem;   /* 72 — hero */\n  --fs-display-l:  3.5rem;   /* 56 */\n  --fs-display-m:  2.75rem;  /* 44 */\n  --fs-h1:         2.25rem;  /* 36 */\n  --fs-h2:         1.75rem;  /* 28 */\n  --fs-h3:         1.375rem; /* 22 */\n  --fs-h4:         1.125rem; /* 18 */\n  --fs-body-lg:    1.1875rem;/* 19 */\n  --fs-body:       1rem;     /* 16 */\n  --fs-body-sm:    0.875rem; /* 14 */\n  --fs-caption:    0.75rem;  /* 12 */\n  --fs-overline:   0.6875rem;/* 11 — eyebrow / wordmark caps */\n\n  /* Line heights */\n  --lh-tight: 1.05; /* @kind font */\n  --lh-snug: 1.18; /* @kind font */\n  --lh-heading: 1.25; /* @kind font */\n  --lh-body: 1.6; /* @kind font */\n  --lh-relaxed: 1.75; /* @kind font */\n\n  /* Letter spacing */\n  --ls-display: -0.02em; /* @kind font */\n  --ls-heading: -0.01em; /* @kind font */\n  --ls-body: 0em; /* @kind font */\n  --ls-overline: 0.18em; /* @kind font */\n  --ls-wordmark: 0.32em; /* @kind font */\n}\n\n/* Curio Group — Spacing, radius, shadow, layout tokens\n   8px base grid with a couple of half-steps for fine control. */\n\n:root {\n  /* Spacing scale */\n  --space-0: 0;\n  --space-1: 0.25rem;  /* 4 */\n  --space-2: 0.5rem;   /* 8 */\n  --space-3: 0.75rem;  /* 12 */\n  --space-4: 1rem;     /* 16 */\n  --space-5: 1.5rem;   /* 24 */\n  --space-6: 2rem;     /* 32 */\n  --space-7: 3rem;     /* 48 */\n  --space-8: 4rem;     /* 64 */\n  --space-9: 6rem;     /* 96 */\n  --space-10: 8rem;    /* 128 */\n\n  /* Radii — Curio leans gently rounded, not pill-everything */\n  --radius-xs: 4px;\n  --radius-sm: 8px;\n  --radius-md: 12px;\n  --radius-lg: 20px;\n  --radius-xl: 28px;\n  --radius-pill: 999px;\n  --radius-blob: 42% 58% 60% 40% / 48% 42% 58% 52%; /* organic brush-shape mask */\n\n  /* Shadows — soft, low, warm-neutral. Curio avoids harsh drops. */\n  --shadow-xs: 0 1px 2px rgba(53, 58, 56, 0.06);\n  --shadow-sm: 0 2px 8px rgba(53, 58, 56, 0.08);\n  --shadow-md: 0 8px 24px rgba(53, 58, 56, 0.10);\n  --shadow-lg: 0 18px 48px rgba(53, 58, 56, 0.14);\n  --shadow-focus: 0 0 0 3px rgba(0, 72, 96, 0.28);\n\n  /* Layout */\n  --container-max: 1200px; /* @kind other */\n  --container-narrow: 760px; /* @kind other */\n  --gutter: var(--space-5); /* @kind spacing */\n\n  /* Motion */\n  --ease-standard: cubic-bezier(0.4, 0, 0.2, 1); /* @kind other */\n  --ease-out: cubic-bezier(0.16, 1, 0.3, 1); /* @kind other */\n  --dur-fast: 140ms; /* @kind other */\n  --dur-med: 240ms; /* @kind other */\n  --dur-slow: 420ms; /* @kind other */\n}\n\n/* Curio Group — light base resets & helpers.\n   Kept minimal: set body type/colour, sensible defaults, brand helpers. */\n\n*,\n*::before,\n*::after {\n  box-sizing: border-box;\n}\n\nbody {\n  margin: 0;\n  font-family: var(--font-sans);\n  font-size: var(--fs-body);\n  line-height: var(--lh-body);\n  font-weight: var(--fw-regular);\n  color: var(--text-strong);\n  background: var(--surface-page);\n  -webkit-font-smoothing: antialiased;\n  text-rendering: optimizeLegibility;\n}\n\nh1, h2, h3, h4, h5, h6 {\n  margin: 0;\n  font-family: var(--font-display);\n  font-weight: var(--fw-extrabold);\n  line-height: var(--lh-heading);\n  letter-spacing: var(--ls-heading);\n  color: var(--text-strong);\n}\n\np { margin: 0; }\n\na {\n  color: var(--text-link);\n  text-decoration: none;\n}\na:hover { text-decoration: underline; }\n\nimg { max-width: 100%; display: block; }\n\n/* ---- Brand helpers ---- */\n\n/* Eyebrow / overline label — used widely across marketing + slides */\n.curio-eyebrow {\n  font-size: var(--fs-overline);\n  font-weight: var(--fw-bold);\n  letter-spacing: var(--ls-overline);\n  text-transform: uppercase;\n}\n\n/* The CURIO | GROUP wordmark treatment in text */\n.curio-wordmark {\n  font-weight: var(--fw-bold);\n  letter-spacing: var(--ls-wordmark);\n  text-transform: uppercase;\n}\n\n/* Container */\n.curio-container {\n  width: 100%;\n  max-width: var(--container-max);\n  margin-inline: auto;\n  padding-inline: var(--gutter);\n}\n\n<\u002Fstyle>\n<script src=\"a24fdce5-ce33-4d9c-942b-a55ffe542ae7\"><\u002Fscript>\n<style>\n  :root{\n    --curio-petrol:#006DAE;--curio-petrol-700:#00466e;--curio-petrol-300:#4a90b8;\n    --curio-forest:#006f29;--curio-forest-700:#00541f;--curio-forest-300:#4f9e6a;\n    --curio-sage:#6f64a9;--curio-sage-300:#a49dcb;--curio-sage-100:#e2dff0;\n    --curio-mustard:#f2a900;--curio-mustard-700:#c33603;\n    --curio-tomato:#c90095;--curio-tomato-700:#a10077;\n    --curio-cream:#EDF0F3;--curio-cream-deep:#E1E5EA;\n    --curio-grey:#E2E5E8;--curio-grey-300:#c7ccd2;--curio-grey-500:#8b9199;\n    --curio-ink:#1f1f1f;--curio-ink-soft:#505050;--curio-white:#ffffff;\n    --status-success:#006f29;\n  }\n  *{box-sizing:border-box;}\n  html,body{margin:0;padding:0;}\n  body{background:var(--curio-cream);font-family:var(--font-sans);-webkit-font-smoothing:antialiased;color:var(--curio-ink);}\n  a{color:var(--curio-petrol);text-decoration:none;}\n  a:hover{color:var(--curio-tomato);text-decoration:underline;}\n  button{font-family:var(--font-sans);}\n<\u002Fstyle>\n<\u002Fhelmet>\n<div style=\"min-height:100vh;background:var(--curio-cream);padding:34px 28px 60px;\">\n  <div style=\"max-width:1280px;margin:0 auto;\">\n\n    <div style=\"display:flex;justify-content:space-between;align-items:flex-end;gap:24px;flex-wrap:wrap;margin-bottom:26px;\">\n      <div style=\"max-width:660px;\">\n        <x-import component-from-global-scope=\"CurioGroupDesignSystem_019e14.Eyebrow\" color=\"tomato\" hint-size=\"auto,14px\">Module 1 · Worked example<\u002Fx-import>\n        <h1 style=\"margin:10px 0 8px;font-size:40px;line-height:1.05;letter-spacing:-0.02em;font-weight:800;color:var(--curio-ink);\">Reading a data table<\u002Fh1>\n        <p style=\"margin:0;font-size:17px;line-height:1.6;color:var(--curio-ink-soft);\">A small extract of 2Market’s regional sales. Click the headers, cells and rows to discover how a structured table is organised — and what each part actually represents.<\u002Fp>\n      <\u002Fdiv>\n      <div style=\"display:flex;align-items:center;gap:12px;flex-wrap:wrap;\">\n        <div style=\"display:inline-flex;background:var(--curio-cream-deep);border-radius:999px;padding:4px;gap:4px;\">\n          <button onclick=\"{{ setTable }}\" style=\"{{ tableTabStyle }}\">Table<\u002Fbutton>\n          <button onclick=\"{{ setCsv }}\" style=\"{{ csvTabStyle }}\">CSV<\u002Fbutton>\n        <\u002Fdiv>\n        <button onclick=\"{{ selectCount }}\" style=\"{{ countChipStyle }}\"><strong style=\"font-weight:800;font-size:15px;color:var(--curio-petrol);\">{{ recordCount }}<\u002Fstrong><span style=\"margin-left:5px;\">records<\u002Fspan><\u002Fbutton>\n        <x-import component-from-global-scope=\"CurioGroupDesignSystem_019e14.Button\" variant=\"primary\" size=\"md\" onclick=\"{{ startTour }}\" hint-size=\"auto,44px\">Take the guided tour<\u002Fx-import>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div style=\"display:grid;grid-template-columns:minmax(0,1fr) 380px;gap:24px;align-items:start;\">\n\n      <div>\n        <div style=\"background:#fff;border-radius:20px;padding:22px;box-shadow:0 8px 24px rgba(53,58,56,0.10);\">\n          <div style=\"display:flex;justify-content:space-between;align-items:baseline;gap:12px;margin-bottom:14px;flex-wrap:wrap;\">\n            <div style=\"font-weight:800;color:var(--curio-petrol);font-size:15px;\">2Market · regional_sales.xlsx<\u002Fdiv>\n            <div style=\"font-size:13px;color:var(--curio-ink-soft);\">{{ tableHint }}<\u002Fdiv>\n          <\u002Fdiv>\n          <sc-if value=\"{{ isTable }}\" hint-placeholder-val=\"{{ true }}\">\n            <div style=\"overflow-x:auto;border-radius:12px;border:1px solid #cdd2cd;-webkit-overflow-scrolling:touch;\">\n              <div style=\"{{ gridStyle }}\">\n                <sc-for list=\"{{ grid }}\" as=\"item\" hint-placeholder-count=\"21\">\n                  <div onclick=\"{{ item.onClick }}\" onmouseenter=\"{{ item.onEnter }}\" onmouseleave=\"{{ item.onLeave }}\" style=\"{{ item.style }}\">{{ item.text }}<\u002Fdiv>\n                <\u002Fsc-for>\n              <\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fsc-if>\n          <sc-if value=\"{{ isCsv }}\" hint-placeholder-val=\"{{ false }}\">\n            <pre style=\"margin:0;background:#00466e;color:#eef2f5;padding:20px;border-radius:12px;font-family:ui-monospace,Menlo,Consolas,monospace;font-size:14px;line-height:1.75;overflow-x:auto;white-space:pre;\">{{ csvText }}<\u002Fpre>\n            <p style=\"margin:14px 2px 0;font-size:14px;line-height:1.6;color:var(--curio-ink-soft);\">Exactly the same data — one record per line. The commas do the job the column borders did above: precise for machines, but far harder for the human eye to read.<\u002Fp>\n          <\u002Fsc-if>\n        <\u002Fdiv>\n\n        <div style=\"display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-top:18px;padding:0 4px;\">\n          <span style=\"font-size:12px;font-weight:800;letter-spacing:0.14em;text-transform:uppercase;color:var(--curio-ink-soft);\">Attributes explored<\u002Fspan>\n          <div style=\"display:flex;gap:8px;flex-wrap:wrap;\">\n            <sc-for list=\"{{ colChips }}\" as=\"chip\" hint-placeholder-count=\"6\">\n              <button onclick=\"{{ chip.onClick }}\" style=\"{{ chip.style }}\">{{ chip.label }}<\u002Fbutton>\n            <\u002Fsc-for>\n          <\u002Fdiv>\n          <span style=\"font-size:14px;font-weight:800;color:var(--curio-forest);margin-left:auto;\">{{ exploredLabel }}<\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <aside style=\"position:sticky;top:24px;display:flex;flex-direction:column;gap:16px;\">\n        <sc-if value=\"{{ mastered }}\" hint-placeholder-val=\"{{ false }}\">\n          <div style=\"background:var(--curio-forest);color:var(--curio-cream);border-radius:14px;padding:13px 16px;font-weight:700;font-size:14px;\">All six attributes explored ✓<\u002Fdiv>\n        <\u002Fsc-if>\n        <div style=\"background:#fff;border-radius:20px;padding:24px;box-shadow:0 8px 24px rgba(53,58,56,0.10);\">\n          <x-import component-from-global-scope=\"CurioGroupDesignSystem_019e14.Eyebrow\" color=\"{{ panel.eyebrowColor }}\" hint-size=\"auto,14px\">{{ panel.eyebrow }}<\u002Fx-import>\n          <h2 style=\"margin:8px 0 0;font-size:23px;font-weight:800;letter-spacing:-0.01em;color:var(--curio-ink);line-height:1.2;word-break:break-word;\">{{ panel.title }}<\u002Fh2>\n          <sc-if value=\"{{ panel.hasBadge }}\" hint-placeholder-val=\"{{ false }}\">\n            <div style=\"margin-top:12px;\">\n              <x-import component-from-global-scope=\"CurioGroupDesignSystem_019e14.Badge\" tone=\"{{ panel.badgeTone }}\" hint-size=\"auto,22px\">{{ panel.badgeLabel }}<\u002Fx-import>\n            <\u002Fdiv>\n          <\u002Fsc-if>\n          <div style=\"margin-top:14px;display:flex;flex-direction:column;gap:10px;\">\n            <sc-for list=\"{{ panel.paras }}\" as=\"para\" hint-placeholder-count=\"2\">\n              <p style=\"margin:0;font-size:15px;line-height:1.6;color:var(--curio-ink-soft);\">{{ para }}<\u002Fp>\n            <\u002Fsc-for>\n          <\u002Fdiv>\n          <sc-if value=\"{{ panel.hasTip }}\" hint-placeholder-val=\"{{ false }}\">\n            <div style=\"margin-top:16px;padding:12px 14px;background:var(--curio-cream);border-radius:12px;font-size:14px;line-height:1.55;color:var(--curio-ink);\"><strong style=\"color:var(--curio-petrol);\">{{ panel.tipLabel }}<\u002Fstrong> {{ panel.tip }}<\u002Fdiv>\n          <\u002Fsc-if>\n          <sc-if value=\"{{ panel.showReset }}\" hint-placeholder-val=\"{{ false }}\">\n            <div style=\"margin-top:18px;\">\n              <x-import component-from-global-scope=\"CurioGroupDesignSystem_019e14.Button\" variant=\"outline\" onclick=\"{{ reset }}\" fullwidth=\"{{ true }}\" hint-size=\"100%,44px\">Explore again<\u002Fx-import>\n            <\u002Fdiv>\n          <\u002Fsc-if>\n        <\u002Fdiv>\n\n        <sc-if value=\"{{ tourActive }}\" hint-placeholder-val=\"{{ false }}\">\n          <div style=\"background:var(--curio-petrol);color:var(--curio-cream);border-radius:20px;padding:20px;\">\n            <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;\">\n              <span style=\"font-size:12px;font-weight:800;letter-spacing:0.14em;text-transform:uppercase;opacity:0.82;\">Guided tour<\u002Fspan>\n              <span style=\"font-size:13px;font-weight:700;opacity:0.9;\">{{ tourStepLabel }}<\u002Fspan>\n            <\u002Fdiv>\n            <div style=\"display:flex;gap:6px;margin-bottom:18px;\">\n              <sc-for list=\"{{ tourDots }}\" as=\"dot\" hint-placeholder-count=\"4\">\n                <span style=\"{{ dot.style }}\"><\u002Fspan>\n              <\u002Fsc-for>\n            <\u002Fdiv>\n            <div style=\"display:flex;gap:10px;\">\n              <button onclick=\"{{ tourBack }}\" style=\"flex:1;padding:11px;border-radius:999px;border:1.5px solid rgba(255,255,255,0.55);background:transparent;color:#ffffff;font-weight:700;font-size:15px;cursor:pointer;\">Back<\u002Fbutton>\n              <button onclick=\"{{ tourNext }}\" style=\"flex:1;padding:11px;border-radius:999px;border:none;background:#ffffff;color:#006DAE;font-weight:800;font-size:15px;cursor:pointer;\">{{ tourNextLabel }}<\u002Fbutton>\n            <\u002Fdiv>\n            <button onclick=\"{{ endTour }}\" style=\"margin-top:12px;background:none;border:none;color:var(--curio-cream);opacity:0.75;font-size:13px;cursor:pointer;text-decoration:underline;\">Exit tour<\u002Fbutton>\n          <\u002Fdiv>\n        <\u002Fsc-if>\n      <\u002Faside>\n\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fdiv>\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\" data-props=\"{&quot;highlightColor&quot;:{&quot;editor&quot;:&quot;enum&quot;,&quot;options&quot;:[&quot;blue&quot;,&quot;purple&quot;,&quot;teal&quot;,&quot;magenta&quot;],&quot;default&quot;:&quot;blue&quot;,&quot;tsType&quot;:&quot;string&quot;,&quot;section&quot;:&quot;Appearance&quot;},&quot;showExcelRefs&quot;:{&quot;editor&quot;:&quot;boolean&quot;,&quot;default&quot;:true,&quot;tsType&quot;:&quot;boolean&quot;,&quot;section&quot;:&quot;Appearance&quot;},&quot;startWithTour&quot;:{&quot;editor&quot;:&quot;boolean&quot;,&quot;default&quot;:false,&quot;tsType&quot;:&quot;boolean&quot;,&quot;section&quot;:&quot;Behaviour&quot;}}\">\nclass Component extends DCLogic {\n  constructor(props){\n    super(props);\n    this.state = {view:'table',selType:null,selCol:null,selRow:null,hoverRow:null,explored:{},tourActive:false,tourStep:0,showRecap:false};\n    this.tourSteps = [{selType:'headerRow'},{selType:'row',selRow:3},{selType:'cell',selRow:3,selCol:4},{selType:'count'}];\n  }\n  componentDidMount(){ if(this.props.startWithTour) this.startTour(); }\n\n  get columns(){\n    return [\n      {key:'transaction_id',label:'transaction_id',letter:'A',type:'Identifier · text',typeTone:'petrol',\n        desc:'A unique code for each transaction. It looks numeric, but it behaves as a label — you would never add or average an ID.',\n        role:'It is what lets you tell one record apart from every other.',\n        tip:'IDs are for matching and joining data, never for arithmetic.'},\n      {key:'region',label:'region',letter:'B',type:'Text · category',typeTone:'forest',\n        desc:'The Australian state where the sale was made.',\n        role:'A category you can group and filter by — for example, total revenue for each region.',\n        tip:'Group the 9 records by region to compare markets.'},\n      {key:'product_category',label:'product_category',letter:'C',type:'Text · category',typeTone:'forest',\n        desc:'The product group that was sold.',\n        role:'Another category for grouping — for example, units sold per category.',\n        tip:'Categories turn raw rows into comparable groups.'},\n      {key:'unit_sales',label:'unit_sales',letter:'D',type:'Number · count',typeTone:'mustard',\n        desc:'A whole-number count of the units sold in this transaction.',\n        role:'Counts can be added up for total units — but never mixed with a currency field.',\n        tip:'Sum unit_sales to get the total units moved.'},\n      {key:'revenue_aud',label:'revenue_aud',letter:'E',type:'Currency · AUD',typeTone:'tomato',\n        desc:'The revenue from the sale. You only know it is in Australian dollars from the column name and its metadata.',\n        role:'A currency field: sum it for total revenue, and keep it apart from counts like unit_sales.',\n        tip:'Never sum revenue_aud alongside unit_sales — they measure different things.'},\n      {key:'transaction_date',label:'transaction_date',letter:'F',type:'Date',typeTone:'petrol',\n        desc:'The date the transaction took place.',\n        role:'A date can be sorted chronologically and grouped into weeks, months, or quarters.',\n        tip:'Dates unlock trends over time.'}\n    ];\n  }\n  get data(){\n    return [\n      ['TX-100231','VIC','Electronics','3','1847.00','2025-01-04'],\n      ['TX-100232','NSW','Apparel','12','642.50','2025-01-04'],\n      ['TX-100233','QLD','Grocery','28','214.80','2025-01-05'],\n      ['TX-100234','WA','Homewares','5','389.95','2025-01-06'],\n      ['TX-100235','VIC','Beauty','9','276.30','2025-01-06'],\n      ['TX-100236','SA','Electronics','2','1299.00','2025-01-07'],\n      ['TX-100237','NSW','Grocery','41','318.70','2025-01-08'],\n      ['TX-100238','QLD','Apparel','7','455.00','2025-01-09'],\n      ['TX-100239','VIC','Homewares','4','512.40','2025-01-10']\n    ];\n  }\n\n  friendlyDate(iso){\n    const m=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];\n    const p=iso.split('-');\n    return parseInt(p[2],10)+' '+m[parseInt(p[1],10)-1]+' '+p[0];\n  }\n  record(r){\n    const row=this.data[r]; const units=row[3];\n    return {id:row[0], summary: row[0]+' recorded '+units+' '+row[2]+' unit'+(units==='1'?'':'s')+' sold in '+row[1]+' on '+this.friendlyDate(row[5])+', earning '+row[4]+' AUD.'};\n  }\n  csvText(){\n    const head=this.columns.map(function(c){return c.key;}).join(',');\n    const rows=this.data.map(function(r){return r.join(',');});\n    return [head].concat(rows).join('\\n');\n  }\n  isExplored(k){ return !!this.state.explored[k]; }\n  highlight(){\n    const m={blue:{bg:'#006DAE',fg:'#ffffff'},purple:{bg:'#6f64a9',fg:'#ffffff'},teal:{bg:'#00739d',fg:'#ffffff'},magenta:{bg:'#c90095',fg:'#ffffff'}};\n    return m[this.props.highlightColor]||m.blue;\n  }\n\n  selectHeader(c){ this.setState(function(st){var e=Object.assign({},st.explored);e[this.columns[c].key]=true;return {selType:'header',selCol:c,selRow:null,tourActive:false,explored:e};}.bind(this)); }\n  selectCell(r,c){ this.setState(function(st){var e=Object.assign({},st.explored);e[this.columns[c].key]=true;return {selType:'cell',selRow:r,selCol:c,tourActive:false,explored:e};}.bind(this)); }\n  selectRow(r){ this.setState({selType:'row',selRow:r,selCol:null,tourActive:false}); }\n  selectHeaderRow(){ this.setState({selType:'headerRow',selCol:null,selRow:null}); }\n  selectCount(){ this.setState({selType:'count',selCol:null,selRow:null,tourActive:false}); }\n  setHover(r){ this.setState({hoverRow:r}); }\n  setView(v){ this.setState({view:v}); }\n  reset(){ this.setState({view:'table',selType:null,selCol:null,selRow:null,hoverRow:null,explored:{},tourActive:false,tourStep:0,showRecap:false}); }\n\n  applyTourStep(i){ const s=this.tourSteps[i]; this.setState({tourActive:true,tourStep:i,selType:s.selType,selCol:(s.selCol==null?null:s.selCol),selRow:(s.selRow==null?null:s.selRow),showRecap:false}); }\n  startTour(){ this.applyTourStep(0); }\n  tourNext(){ const i=this.state.tourStep; if(i>=this.tourSteps.length-1){ this.setState({tourActive:false,showRecap:true,selType:null,selCol:null,selRow:null}); } else { this.applyTourStep(i+1); } }\n  tourBack(){ const i=this.state.tourStep; if(i>0) this.applyTourStep(i-1); }\n  endTour(){ this.setState({tourActive:false,selType:null,selCol:null,selRow:null}); }\n\n  gridStyle(){\n    const refs=this.props.showExcelRefs!==false;\n    const c=refs?'40px repeat(6, minmax(112px,1fr))':'repeat(6, minmax(112px,1fr))';\n    return {display:'grid',gridTemplateColumns:c,gap:'1px',background:'#DDE1E6',minWidth:'max-content'};\n  }\n  buildGrid(){\n    const s=this.state, cols=this.columns, data=this.data, hl=this.highlight();\n    const refs=this.props.showExcelRefs!==false;\n    const items=[];\n    const colOn=function(c){return ((s.selType==='header'||s.selType==='cell')&&s.selCol===c)||s.selType==='headerRow';};\n    const rowOn=function(r){return ((s.selType==='row'||s.selType==='cell')&&s.selRow===r)||s.hoverRow===r;};\n    const facet={fontSize:'12px',fontWeight:800,color:'#505050',padding:'8px',display:'flex',alignItems:'center',justifyContent:'center',letterSpacing:'0.02em'};\n    if(refs){\n      items.push({key:'corner',text:'',style:{background:'#EEF1F4'}});\n      cols.forEach(function(col,c){ items.push({key:'L'+c,text:col.letter,style:Object.assign({},facet,{background:colOn(c)?'rgba(0,109,174,0.14)':'#EEF1F4',color:colOn(c)?'#006DAE':'#505050'})}); });\n      items.push({key:'rn1',text:'1',onClick:this.selectHeaderRow.bind(this),style:Object.assign({},facet,{cursor:'pointer',background:s.selType==='headerRow'?'rgba(0,109,174,0.14)':'#EEF1F4'})});\n    }\n    cols.forEach(function(col,c){\n      const strong=s.selType==='header'&&s.selCol===c;\n      const soft=s.selType==='headerRow';\n      const st={padding:'12px 13px',fontSize:'13px',fontWeight:800,cursor:'pointer',color:strong?hl.fg:'#00557e',background:strong?hl.bg:(soft?'rgba(0,109,174,0.16)':'#EEF1F4'),whiteSpace:'nowrap',display:'flex',alignItems:'center',transition:'background 140ms ease',borderBottom:this.isExplored(col.key)?'2px solid #006f29':'2px solid transparent'};\n      items.push({key:'H'+c,text:col.label,onClick:this.selectHeader.bind(this,c),style:st});\n    }.bind(this));\n    data.forEach(function(row,r){\n      if(refs){ items.push({key:'rn'+r,text:String(r+2),onClick:this.selectRow.bind(this,r),style:Object.assign({},facet,{cursor:'pointer',background:rowOn(r)?'rgba(0,109,174,0.12)':'#EEF1F4'})}); }\n      row.forEach(function(val,c){\n        const strong=s.selType==='cell'&&s.selRow===r&&s.selCol===c;\n        const rt=rowOn(r); const ct=((s.selType==='header'||s.selType==='cell')&&s.selCol===c);\n        let bg='#fff';\n        if(strong) bg=hl.bg; else if(rt) bg='rgba(0,109,174,0.08)'; else if(ct) bg='rgba(111,100,169,0.10)';\n        const numeric=(c===3||c===4);\n        const st={padding:'11px 13px',fontSize:'14px',cursor:'pointer',whiteSpace:'nowrap',display:'flex',alignItems:'center',transition:'background 140ms ease',background:bg,color:strong?hl.fg:'#1f1f1f',fontWeight:strong?700:400,justifyContent:numeric?'flex-end':'flex-start',fontVariantNumeric:numeric?'tabular-nums':'normal'};\n        items.push({key:'c'+r+'_'+c,text:val,onClick:this.selectCell.bind(this,r,c),onEnter:this.setHover.bind(this,r),onLeave:this.setHover.bind(this,null),style:st});\n      }.bind(this));\n    }.bind(this));\n    return items;\n  }\n\n  tabStyle(active){ return {padding:'8px 18px',borderRadius:'999px',border:'none',cursor:'pointer',fontWeight:700,fontSize:'14px',background:active?'#006DAE':'transparent',color:active?'#ffffff':'#505050',transition:'all 140ms ease'}; }\n  countChipStyle(on){ return {display:'inline-flex',alignItems:'center',padding:'8px 15px',borderRadius:'999px',border:'1.5px solid '+(on?'#006DAE':'rgba(0,0,0,0.2)'),background:on?'rgba(0,109,174,0.08)':'#fff',color:'#1f1f1f',fontSize:'14px',cursor:'pointer',fontWeight:600,boxShadow:on?'0 0 0 3px rgba(0,109,174,0.18)':'none',transition:'all 140ms ease'}; }\n  chipStyle(explored,active){\n    const base={padding:'6px 12px',borderRadius:'999px',fontSize:'13px',fontWeight:600,cursor:'pointer',transition:'all 140ms ease'};\n    const look=explored?{background:'#006f29',color:'#ffffff',border:'1.5px solid #006f29'}:{background:'#fff',color:'#006DAE',border:'1.5px solid rgba(0,109,174,0.4)'};\n    const ring=active?{boxShadow:'0 0 0 3px rgba(0,109,174,0.18)'}:{};\n    return Object.assign(base,look,ring);\n  }\n  colChips(){\n    return this.columns.map(function(col,c){\n      return {label:col.label,onClick:this.selectHeader.bind(this,c),style:this.chipStyle(this.isExplored(col.key),this.state.selType==='header'&&this.state.selCol===c)};\n    }.bind(this));\n  }\n  dotStyle(active,done){ return {width:'8px',height:'8px',borderRadius:'50%',background:active?'#ffffff':(done?'rgba(255,255,255,0.9)':'rgba(255,255,255,0.35)'),transition:'all 140ms ease'}; }\n\n  computePanel(){\n    const s=this.state, cols=this.columns, n=this.data.length;\n    if(s.selType==='header'){\n      const col=cols[s.selCol];\n      return {eyebrow:'Column '+col.letter+' · attribute',eyebrowColor:'petrol',title:col.label,hasBadge:true,badgeTone:col.typeTone,badgeLabel:col.type,paras:[col.desc,col.role],hasTip:true,tipLabel:'Why it matters:',tip:col.tip,showReset:false};\n    }\n    if(s.selType==='cell'){\n      const col=cols[s.selCol]; const val=this.data[s.selRow][s.selCol]; const addr=col.letter+(s.selRow+2); const rec=this.record(s.selRow);\n      return {eyebrow:'Cell '+addr,eyebrowColor:'tomato',title:val,hasBadge:true,badgeTone:col.typeTone,badgeLabel:col.type,paras:['This is the '+col.label+' for record '+(s.selRow+1)+' — '+rec.summary,'One cell holds one value: a single attribute ('+col.label+') for a single record.'],hasTip:true,tipLabel:'Address:',tip:'Analysts refer to this cell as '+addr+' — column '+col.letter+', row '+(s.selRow+2)+'.',showReset:false};\n    }\n    if(s.selType==='row'){\n      const rec=this.record(s.selRow);\n      return {eyebrow:'Record '+(s.selRow+1)+' of '+n,eyebrowColor:'forest',title:rec.id,hasBadge:false,paras:['Each row below the header is one record — a single 2Market transaction.',rec.summary],hasTip:true,tipLabel:'Reading a row:',tip:'Left to right, the six cells describe this one sale across every attribute.',showReset:false};\n    }\n    if(s.selType==='headerRow'){\n      return {eyebrow:'Row 1 · the header',eyebrowColor:'petrol',title:'The header row',hasBadge:false,paras:['The first row holds no data of its own — it names every column.','Each name is an attribute (or variable) that all records share. It is what makes the table readable at a glance.'],hasTip:true,tipLabel:'Watch out:',tip:'The header is never counted as a record.',showReset:false};\n    }\n    if(s.selType==='count'){\n      return {eyebrow:'Record count',eyebrowColor:'mustard',title:n+' records',hasBadge:false,paras:['The record count is the total number of data rows — not including the header.','It is the first thing analysts check: it tells you how much data you are actually holding.'],hasTip:true,tipLabel:'Here:',tip:'6 attributes described across '+n+' transactions.',showReset:false};\n    }\n    if(s.showRecap){\n      return {eyebrow:'Nice work',eyebrowColor:'forest',title:'You have read the table',hasBadge:false,paras:['Rows are records — each of the '+n+' rows is one 2Market transaction.','Columns are attributes — each of the 6 columns is one field every record shares.','Types decide what you can do: currency (revenue_aud) sums for totals, counts (unit_sales) sum separately, and dates (transaction_date) sort and group by period.'],hasTip:false,showReset:true};\n    }\n    return {eyebrow:'Start here',eyebrowColor:'tomato',title:'Explore the table',hasBadge:false,paras:['This is a small extract of 2Market’s regional sales — structured data, organised into rows and columns.','Click a column header, a single cell, a row number, or the record count to see what each part represents.'],hasTip:true,tipLabel:'New to this?',tip:'Take the guided tour for a quick walkthrough.',showReset:false};\n  }\n\n  renderVals(){\n    const s=this.state, n=this.data.length;\n    const isCsv=s.view==='csv', isTable=!isCsv;\n    const exploredCount=Object.keys(s.explored).length;\n    const mastered=exploredCount>=6;\n    const countHighlight=s.selType==='count';\n    const self=this;\n    return {\n      grid:this.buildGrid(),\n      gridStyle:this.gridStyle(),\n      isTable:isTable, isCsv:isCsv,\n      csvText:this.csvText(),\n      tableHint:'Structured data — 6 attributes × '+n+' records',\n      panel:this.computePanel(),\n      recordCount:n,\n      exploredLabel: mastered? 'All explored ✓' : (exploredCount+' / 6'),\n      mastered:mastered,\n      colChips:this.colChips(),\n      tourActive:s.tourActive,\n      tourStepLabel:'Step '+(s.tourStep+1)+' of '+this.tourSteps.length,\n      tourNextLabel: s.tourStep>=this.tourSteps.length-1? 'Finish' : 'Next',\n      tourDots:this.tourSteps.map(function(t,i){return {style:self.dotStyle(i===s.tourStep,i<s.tourStep)};}),\n      countChipStyle:this.countChipStyle(countHighlight),\n      tableTabStyle:this.tabStyle(isTable),\n      csvTabStyle:this.tabStyle(isCsv),\n      setTable:function(){self.setView('table');},\n      setCsv:function(){self.setView('csv');},\n      startTour:function(){self.startTour();},\n      reset:function(){self.reset();},\n      tourNext:function(){self.tourNext();},\n      tourBack:function(){self.tourBack();},\n      endTour:function(){self.endTour();},\n      selectCount:function(){self.selectCount();}\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
